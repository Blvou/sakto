{
  "mcpServers": {
    "supabase": {
      "url": "https://mcp.supabase.com/mcp?project_ref=gpducxpyvfolsnhejkon"
    },
    "github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "envFile": "${workspaceFolder}/.env"
    },
    "vercel": {
      "url": "https://mcp.vercel.com"
    }
  }
}
